// balduraddb01.baf
@1001 = ~Narlen Darkwalk i jego łotrzykowie umieścili w twojej skrzyni skarby.~

// tsdrunk1.baf
@1003 = ~Jestem nowy w mieście. Podpowiesz mi, jak trafić do twojego mieszkania?~
@1004 = ~A może ja podpowiem mojej pięści, jak trafić w twoją twarz?~

@1005 = ~Czy nie widziałem cię gdzieś wcześniej?~
@1006 = ~Tak. Dlatego już tam nie chodzę.~

@1007 = ~To co, wracamy do mnie?~
@1008 = ~No nie wiem. Dwie osoby zmieszczą się w jaskini?~

@1009 = ~Do ciebie czy do mnie?~
@1010 = ~Do obu. Ty idziesz do siebie, ja do siebie.~

@1011 = ~Hej, piękna, jaki masz znak?~
@1012 = ~Nie wchodzić.~

@1013 = ~Jak lubisz jajka o poranku?~
@1014 = ~Niezapłodnione!~

@1015 = ~Wiem, jak zadowolić kobietę.~
@1016 = ~To zacznij od zostawienia mnie w spokoju.~

@1017 = ~Chcę ci się oddać.~
@1018 = ~Przykro mi, nie przyjmuję tanich prezentów.~

@1019 = ~Widzę, że mnie pragniesz.~
@1020 = ~Ooo, masz rację. Pragnę, żebyś sobie poszedł.~

@1021 = ~Gdybym mógł zobaczyć cię nago, umarłbym szczęśliwy.~
@1022 = ~Tak, ale gdybym to ja zobaczyła ciebie nago, chyba umarłabym ze śmiechu.~

@1023 = ~Hej, laseczko, co powiesz na odwiedzenie paru gorących miejsc?~
@1024 = ~Przykro mi, nie umawiam się poza własnym gatunkiem...~

@1025 = ~Twoje ciało jest jak świątynia.~
@1026 = ~Przykro mi, dziś nie ma nabożeństw.~

@1027 = ~Przeszedłbym dla ciebie przez wszystko.~
@1028 = ~Świetnie! Zacznijmy od twojej głowy przez najbliższą ścianę.~

@1029 = ~Poszedłbym dla ciebie na koniec świata.~
@1030 = ~Tak? A zostałbyś tam?~

@1031 = ~Hej, piękna. Może spotkamy się po twojej zmianie?~
@1032 = ~Hmm? Wiesz... jesteś tak żałosny, że aż trochę uroczy.~

@1033 = ~Naprawdę?~

// tsgbase.baf
@1034 = ~Może byś trochę pomógł, co?~

// tswench1.baf
// ------------
@1035 = ~Proszę, chłopcze.~
@1036 = ~Oooch! Moje biedne, obolałe nogi!~
